{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "manual",
    "deny": [
      "Bash(rm -rf*)",
      "Bash(printenv*)",
      "Bash(env)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(parted*)",
      "Bash(shred*)",
      "Bash(find * -delete*)"
    ]
  },
  "profiles": {
    "team-lead": {
      "permissions": {
        "defaultMode": "default",
        "allow": ["Bash(agent-team *)", "Bash(git *)"]
      }
    },
    "architect": {
      "permissions": {
        "defaultMode": "manual",
        "deny": ["Write(*)", "Edit(*)", "Bash(*)"],
        "allow": ["Bash(agent-team plan *)"]
      }
    },
    "developer": {
      "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
          "Bash(agent-team run *)",
          "Bash(git add *)",
          "Bash(git commit *)"
        ]
      }
    },
    "reviewer": {
      "permissions": {
        "defaultMode": "manual",
        "deny": ["Write(*)", "Edit(*)", "Bash(*)"],
        "allow": [
          "Bash(agent-team validate *)",
          "Bash(git diff *)",
          "Bash(git log *)"
        ]
      }
    },
    "qa": {
      "permissions": {
        "defaultMode": "acceptEdits",
        "deny": ["Write(src/*)", "Edit(src/*)"],
        "allow": [
          "Bash(agent-team run --dry-run*)",
          "Bash(bun test*)",
          "Bash(npm test*)"
        ]
      }
    }
  }
}
