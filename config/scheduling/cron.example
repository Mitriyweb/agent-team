# Claude Code Agent Team — Cron Examples
#
# Edit with: crontab -e
# Logs go to: .claude-loop/cron.log

# Run one task every hour
0 * * * * cd /path/to/project && ./scripts/run.sh >> .claude-loop/cron.log 2>&1

# Run all pending tasks every night at 2am
0 2 * * * cd /path/to/project && ./scripts/run.sh --all >> .claude-loop/cron.log 2>&1

# Run on weekdays only at 9am
0 9 * * 1-5 cd /path/to/project && ./scripts/run.sh >> .claude-loop/cron.log 2>&1
