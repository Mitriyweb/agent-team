# Frontend Specialist Team Configuration

# Framework to use (e.g., React, Vue, Svelte, Angular)
FRONTEND_FRAMEWORK=React

# Styling approach (e.g., Tailwind, CSS-Modules, Styled-Components, Sass)
CSS_APPROACH=Tailwind

# Path to design tokens / theme definition
DESIGN_TOKENS_PATH=src/styles/tokens.json

# URL to the reference design (Figma, Sketch, etc.)
FIGMA_FILE_URL=https://www.figma.com/file/...

# Accessibility standard baseline
A11Y_STANDARD=WCAG 2.1 AA

# Visual regression tool/service
VISUAL_REGRESSION=Playwright-Snapshots
