{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": "bash scripts/audit-hook.sh PRE",
    "PostToolUse": "bash scripts/audit-hook.sh POST"
  },
  "permissions": {
    "defaultMode": "manual",
    "deny": [
      "Bash(rm -rf*)",
      "Bash(printenv*)",
      "Bash(env)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(parted*)",
      "Bash(shred*)",
      "Bash(find * -delete*)"
    ]
  },
  "profiles": {
    "manual": {
      "permissions": {
        "defaultMode": "manual"
      }
    },
    "acceptEdits": {
      "permissions": {
        "defaultMode": "acceptEdits"
      }
    },
    "readOnly": {
      "permissions": {
        "defaultMode": "manual",
        "deny": ["Write(*)", "Edit(*)", "Bash(*)"]
      }
    },
    "testOnly": {
      "permissions": {
        "defaultMode": "acceptEdits",
        "deny": ["Write(src/*)", "Edit(src/*)"]
      }
    }
  }
}
