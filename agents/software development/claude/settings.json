{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "manual",
    "deny": [
      "Bash(rm -rf*)",
      "Bash(printenv*)",
      "Bash(env)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(parted*)",
      "Bash(shred*)",
      "Bash(find * -delete*)"
    ],
    "hooks": {
      "PreToolUse": "bash scripts/audit-hook.sh",
      "PostToolUse": "bash scripts/audit-hook.sh"
    },
    "profiles": {
      "team-lead": {
        "mode": "default",
        "deny": []
      },
      "architect": {
        "mode": "default",
        "deny": [
          "Write(*)",
          "Edit(*)",
          "Bash(*)"
        ]
      },
      "developer": {
        "mode": "acceptEdits",
        "deny": []
      },
      "reviewer": {
        "mode": "default",
        "deny": [
          "Write(*)",
          "Edit(*)",
          "Bash(*)"
        ]
      },
      "qa": {
        "mode": "acceptEdits",
        "deny": [
          "Write(src/*)",
          "Edit(src/*)"
        ]
      }
    }
  }
}
