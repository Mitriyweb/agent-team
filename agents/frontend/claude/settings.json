{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1"
  },
  "plugins": ["playwright@claude-plugins-official"],
  "permissions": {
    "allow": ["Bash(npx playwright*)"],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(printenv*)",
      "Bash(env)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(parted*)",
      "Bash(shred*)",
      "Bash(find * -delete*)"
    ]
  }
}
