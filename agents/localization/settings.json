{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "agent-team audit-hook PRE 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "agent-team audit-hook POST 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(rm -rf*)",
      "Bash(printenv*)",
      "Bash(env)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(parted*)",
      "Bash(shred*)",
      "Bash(find * -delete*)"
    ]
  },
  "profiles": {
    "team-lead": {
      "permissions": {
        "defaultMode": "default",
        "allow": [
          "Bash(agent-team *)",
          "Bash(bun bin/init.ts *)",
          "Bash(git *)"
        ]
      }
    },
    "localizer": {
      "permissions": {
        "defaultMode": "acceptEdits",
        "allow": ["Bash(agent-team run *)", "Bash(bun bin/init.ts run *)"]
      }
    },
    "tech-writer": {
      "permissions": {
        "defaultMode": "acceptEdits",
        "allow": ["Bash(agent-team run *)", "Bash(bun bin/init.ts run *)"]
      }
    },
    "seo-specialist": {
      "permissions": {
        "defaultMode": "acceptEdits",
        "deny": ["Bash(*)"],
        "allow": [
          "Bash(agent-team validate *)",
          "Bash(bun bin/init.ts validate *)"
        ]
      }
    },
    "qa": {
      "permissions": {
        "defaultMode": "acceptEdits",
        "deny": ["Write(src/*)", "Edit(src/*)"],
        "allow": [
          "Bash(agent-team run --dry-run*)",
          "Bash(bun bin/init.ts run --dry-run*)",
          "Bash(bun test*)",
          "Bash(npm test*)"
        ]
      }
    }
  }
}
