# ─────────────────────────────────────────────────────────────────
#  Provider: oauth | anthropic | azure-apim | azure-apim-oauth | litellm
#
#  Default: oauth (uses existing `claude /login` session, no keys needed)
# ─────────────────────────────────────────────────────────────────
PROVIDER=oauth

# ── OAuth (default) ──────────────────────────────────────────
# No keys needed. Run `claude` once to login via browser.
# Optionally route through a proxy:
# ANTHROPIC_BASE_URL=https://apim-multimodel-common.azure-api.net/anthropic-model/anthropic/v1

# ── Anthropic (direct API key) ───────────────────────────────
# PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Azure APIM (with subscription key) ──────────────────────
# PROVIDER=azure-apim
# AZURE_APIM_ENDPOINT=https://apim-multimodel-common.azure-api.net/anthropic-model/anthropic/v1
# AZURE_APIM_KEY=your-subscription-key

# ── Azure APIM (OAuth, no key needed) ───────────────────────
# PROVIDER=azure-apim-oauth
# AZURE_APIM_ENDPOINT=https://apim-multimodel-common.azure-api.net/anthropic-model/anthropic/v1

# ── LiteLLM (local proxy) ───────────────────────────────────
# PROVIDER=litellm
# LITELLM_HOST=http://localhost:8080
# LITELLM_API_KEY=local-key

# ── Model pinning (optional) ────────────────────────────────
# Pin specific model versions if your provider doesn't have the latest
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-5-20250514
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5-20241022
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001

# ── SDK mode (--sdk flag) ──────────────────────────────────
# Path to Claude Code CLI binary (SDK requires it under the hood)
# Default: auto-detected from node_modules or PATH
# CLAUDE_CLI_PATH=/app/node_modules/.bin/claude
